# pip install gensim matplotlib scikit-learn
import gensim.downloader as api
from sklearn.decomposition import PCA
import matplotlib.pyplot as plt

m = api.load("word2vec-google-news-300")
words = ['computer', 'internet', 'software', 'hardware', 'keyboard', 'mouse', 'server', 'network', 'programming', 'database']
reduced = PCA(n_components=2).fit_transform([m[w] for w in words])

input_word = 'computer'
print(f"Top 5 words similar to '{input_word}':")
for word, score in m.most_similar(input_word, topn=5):
    print(f"{word}: {score:.4f}")

plt.figure(figsize=(8, 6))
for i, w in enumerate(words):
    plt.scatter(reduced[i, 0], reduced[i, 1])
    plt.annotate(w, (reduced[i, 0], reduced[i, 1]))
plt.title("PCA Visualization of Technology Word Embeddings")
plt.xlabel("PC1"); plt.ylabel("PC2"); plt.grid(True)
plt.show()
